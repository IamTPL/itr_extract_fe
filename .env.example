# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ── Backend API base URL ──
VITE_API_BASE_URL=http://localhost:8000

# ── Azure AD (Microsoft Entra) ──
# CLIENT_ID = BE_CLIENT_ID (cùng app registration cho FE + BE API)
VITE_MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_MSAL_BE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# DEV mode: để trống VITE_MSAL_TENANT_ID
#   - authority = /common (cho phép personal + work accounts)
#   - FE gửi ID token cho BE (vì personal accounts không support custom API scope)
# PRODUCTION: điền tenant ID của khách hàng
#   - authority = /<tenant-id> (chỉ org đó login được)
#   - FE request BE_SCOPE và gửi access token cho BE (chuẩn OAuth2)
VITE_MSAL_TENANT_ID=
